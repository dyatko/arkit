tils" style="stroke: #0; stroke-width: 0;"/><!--link cli to yargs--><!--link _config to _types--><!--link _config to utils--><!--link _converter to logger--><!--link _converter to node-plantuml--><!--link _converter to _types--><!--link <b>eslint.config</b> to eslint-config-prettier--><path d="M0,0 C0,0 0,0 0,0 " fill="none" id="&lt;b&gt;eslint.config&lt;/b&gt;-eslint-config-prettier" style="stroke: #0; stroke-width: 0;"/><!--link _filesystem to logger--><!--link _filesystem to resolve--><!--link _filesystem to _schema--><!--link _filesystem to ts-morph--><!--link _filesystem to tsconfig-paths--><!--link _filesystem to _types--><!--link _filesystem to utils--><!--link _generator to _types--><!--link _generator to utils--><!--link logger to pino--><!--link _parser to _filesystem--><!--link _parser to progress--><!--link _parser to ts-morph--><!--link _parser to _types--><!--link _parser to utils--><!--link _puml to _schema--><!--link _puml to _types--><!--link _puml to utils--><!--link _types to _schema--><!--link utils to logger--><!--link utils to nanomatch--><!--link utils to ts-morph--><!--link utils to _types--><!--link <b>dot-wasm</b> to <b>hpcc-wasm.d</b>--><!--link <b>dot-wasm</b> to <b>index</b>--><!--link <b>index</b> to <b>node-plantuml.d</b>--><!--
@startuml

scale max 0 width
left to right direction

skinparam nodesep 0
skinparam ranksep 0
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Tahoma
skinparam defaultFontSize 0
skinparam roundCorner 0
skinparam dpi 0
skinparam arrowColor black
skinparam arrowThickness 0
skinparam packageTitleAlignment left

skinparam usecase {
  borderThickness 0
}

skinparam rectangle {
  borderThickness 0
}

skinparam component {
  borderThickness 0
}


(<b>arkit</b>)
(cli)
rectangle "config" as _config
rectangle "converter" as _converter
(<b>dot-wasm</b>)
(<b>eslint.config</b>)
rectangle "filesystem" as _filesystem
rectangle "generator" as _generator
(<b>hpcc-wasm.d</b>)
(<b>index</b>)
(logger)
(<b>node-plantuml.d</b>)
rectangle "parser" as _parser
rectangle "puml" as _puml
rectangle "schema" as _schema
rectangle "types" as _types
(utils)

package "Dependencies" {
  [eslint-config-prettier]
  [nanomatch]
  [node-plantuml]
  [pino]
  [progress]
  [resolve]
  [ts-morph]
  [tsconfig-paths]
  [yargs]
}

(<b>arkit</b>) -[thickness=0]> (cli)
(<b>arkit</b>) -[thickness=0]> _config
(<b>arkit</b>) -[thickness=0]> _converter
(<b>arkit</b>) -[thickness=0]> _generator
(<b>arkit</b>) -[thickness=0]> _parser
(<b>arkit</b>) - - -[thickness=0]> [progress]
(<b>arkit</b>) -[thickness=0]> _puml
(<b>arkit</b>) -[thickness=0]> _types
(<b>arkit</b>) -[thickness=0]> (utils)
(cli) - - -> [yargs]
_config - -> _types
_config - -> (utils)
_converter - -> (logger)
_converter - - -> [node-plantuml]
_converter - -> _types
(<b>eslint.config</b>) - -[thickness=0]> [eslint-config-prettier]
_filesystem - -> (logger)
_filesystem - - -> [resolve]
_filesystem - -> _schema
_filesystem - - -> [ts-morph]
_filesystem - - -> [tsconfig-paths]
_filesystem - -> _types
_filesystem - -> (utils)
_generator - -> _types
_generator - -> (utils)
(logger) - - -> [pino]
_parser - -> _filesystem
_parser - - -> [progress]
_parser - - -> [ts-morph]
_parser - -> _types
_parser - -> (utils)
_puml - -> _schema
_puml - -> _types
_puml - -> (utils)
_types - -> _schema
(utils) - -> (logger)
(utils) - - -> [nanomatch]
(utils) - - -> [ts-morph]
(utils) - -> _types

@enduml

PlantUML version NORMALIZED
(GPL source distribution)
Java Runtime: OpenJDK Runtime Environment
JVM: OpenJDK 0-Bit Server VM
Java Version: NORMALIZED
Operating System: NORMALIZED
OS Version: NORMALIZED
Default Encoding: UTF-0
Language: en
Country: NORMALIZED
--></g></svg>"
`;

