troke-width: 0.5;"/><polygon fill="#000000" points="490.45,265.98,483.1261,272.5649,488.41,270.5449,490.43,275.8288,490.45,265.98" style="stroke: #000000; stroke-width: 0.5;"/><!--link <b>hpcc-wasm.d</b> to <b>index</b>--><!--link <b>hpcc-wasm.d</b> to <b>node-plantuml.d</b>--><!--
@startuml

scale max 1920 width
left to right direction

skinparam nodesep 17
skinparam ranksep 34
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Tahoma
skinparam defaultFontSize 12
skinparam roundCorner 6
skinparam dpi 150
skinparam arrowColor black
skinparam arrowThickness 0.5
skinparam packageTitleAlignment left

skinparam usecase {
  borderThickness 0.5
}

skinparam rectangle {
  borderThickness 0.5
}

skinparam component {
  borderThickness 1
}


(<b>arkit</b>)
(cli)
rectangle "config" as _config
rectangle "converter" as _converter
(<b>dot-wasm</b>)
(<b>eslint.config</b>)
rectangle "filesystem" as _filesystem
rectangle "generator" as _generator
(<b>hpcc-wasm.d</b>)
(<b>index</b>)
(logger)
(<b>node-plantuml.d</b>)
rectangle "parser" as _parser
rectangle "puml" as _puml
rectangle "schema" as _schema
rectangle "types" as _types
(utils)

package "Dependencies" {
  [@hpcc-js]
  [eslint-config-prettier]
  [nanomatch]
  [node-plantuml]
  [pino]
  [progress]
  [resolve]
  [ts-morph]
  [tsconfig-paths]
  [yargs]
}

(<b>arkit</b>) -[thickness=1]> (cli)
(<b>arkit</b>) -[thickness=1]> _config
(<b>arkit</b>) -[thickness=1]> _converter
(<b>arkit</b>) -[thickness=1]> _generator
(<b>arkit</b>) -[thickness=1]> _parser
(<b>arkit</b>) - - -[thickness=1]> [progress]
(<b>arkit</b>) -[thickness=1]> _puml
(<b>arkit</b>) -[thickness=1]> _types
(<b>arkit</b>) -[thickness=1]> (utils)
(cli) - - -> [yargs]
_config - -> _types
_config - -> (utils)
_converter - -> (logger)
_converter - - -> [node-plantuml]
_converter - -> _types
(<b>dot-wasm</b>) - - -[thickness=1]> [@hpcc-js]
(<b>eslint.config</b>) - -[thickness=1]> [eslint-config-prettier]
_filesystem - -> (logger)
_filesystem - - -> [resolve]
_filesystem - -> _schema
_filesystem - - -> [ts-morph]
_filesystem - - -> [tsconfig-paths]
_filesystem - -> _types
_filesystem - -> (utils)
_generator - -> _types
_generator - -> (utils)
(logger) - - -> [pino]
_parser - -> _filesystem
_parser - - -> [progress]
_parser - - -> [ts-morph]
_parser - -> _types
_parser - -> (utils)
_puml - -> _schema
_puml - -> _types
_puml - -> (utils)
_types - -> _schema
(utils) - -> (logger)
(utils) - - -> [nanomatch]
(utils) - - -> [ts-morph]
(utils) - -> _types

@enduml

