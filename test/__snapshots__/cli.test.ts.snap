lengthAdjust="spacingAndGlyphs" textLength="0" x="0" y="0">route</text><ellipse cx="0" cy="0" fill="#F0F0F0" rx="0" ry="0" style="stroke: #0; stroke-width: 0;"/><text fill="#0" font-family="Tahoma" font-size="0" lengthAdjust="spacingAndGlyphs" textLength="0" x="0" y="0">router</text><ellipse cx="0" cy="0" fill="#F0F0F0" rx="0" ry="0" style="stroke: #0; stroke-width: 0;"/><text fill="#0" font-family="Tahoma" font-size="0" lengthAdjust="spacingAndGlyphs" textLength="0" x="0" y="0">utils</text><ellipse cx="0" cy="0" fill="#F0F0F0" rx="0" ry="0" style="stroke: #0; stroke-width: 0;"/><text fill="#0" font-family="Tahoma" font-size="0" lengthAdjust="spacingAndGlyphs" textLength="0" x="0" y="0">view</text><!--link application to init--><!--link application to query--><!--link application to router--><!--link application to utils--><!--link application to view--><!--link <b>express</b> to application--><path d="M0,0 C0,0 0,0 0,0 C0,0 0,0 0,0 C0,0 0,0 0,0 " fill="none" id="&lt;b&gt;express&lt;/b&gt;-application" style="stroke: #0; stroke-width: 0;"/><!--link <b>express</b> to query--><path d="M0,0 C0,0 0,0 0,0 " fill="none" id="&lt;b&gt;express&lt;/b&gt;-query" style="stroke: #0; stroke-width: 0;"/><!--link <b>express</b> to request--><path d="M0,0 C0,0 0,0 0,0 " fill="none" id="&lt;b&gt;express&lt;/b&gt;-request" style="stroke: #0; stroke-width: 0;"/><!--link <b>express</b> to response--><path d="M0,0 C0,0 0,0 0,0 C0,0 0,0 0,0 C0,0 0,0 0,0 " fill="none" id="&lt;b&gt;express&lt;/b&gt;-response" style="stroke: #0; stroke-width: 0;"/><!--link <b>express</b> to route--><path d="M0,0 C0,0 0,0 0,0 " fill="none" id="&lt;b&gt;express&lt;/b&gt;-route" style="stroke: #0; stroke-width: 0;"/><!--link <b>express</b> to router--><path d="M0,0 C0,0 0,0 0,0 " fill="none" id="&lt;b&gt;express&lt;/b&gt;-router" style="stroke: #0; stroke-width: 0;"/><!--link response to utils--><!--link route to layer--><!--link router to layer--><!--link router to route--><!--
@startuml

scale max 0 width
top to bottom direction

skinparam nodesep 0
skinparam ranksep 0
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Tahoma
skinparam defaultFontSize 0
skinparam roundCorner 0
skinparam dpi 0
skinparam arrowColor black
skinparam arrowThickness 0
skinparam packageTitleAlignment left

skinparam usecase {
  borderThickness 0
}

skinparam rectangle {
  borderThickness 0
}

skinparam component {
  borderThickness 0
}


(application)
(<b>express</b>)
(init)
(layer)
(query)
(request)
(response)
(route)
(router)
(utils)
(view)


(application) - -> (init)
(application) - -> (query)
(application) - -> (router)
(application) - -> (utils)
(application) - -> (view)
(<b>express</b>) -[thickness=0]> (application)
(<b>express</b>) -[thickness=0]> (query)
(<b>express</b>) -[thickness=0]> (request)
(<b>express</b>) -[thickness=0]> (response)
(<b>express</b>) -[thickness=0]> (route)
(<b>express</b>) -[thickness=0]> (router)
(response) - -> (utils)
(route) - -> (layer)
(router) - -> (layer)
(router) - -> (route)

@enduml

PlantUML version NORMALIZED
(GPL source distribution)
Java Runtime: OpenJDK Runtime Environment
JVM: OpenJDK 0-Bit Server VM
Java Version: NORMALIZED
Operating System: NORMALIZED
OS Version: NORMALIZED
Default Encoding: UTF-0
Language: en
Country: NORMALIZED
--></g></svg>"
`;

exports[`CLI Options should output help 1`] = `
"arkit [directory]

Options:
  -d, --directory  Working directory
  -c, --config     Config file path (json or js)
  -o, --output     Output path or type (svg, png or puml)
  -f, --first      File patterns to be first in the graph               [string]
  -e, --exclude    File patterns to exclude from the graph
  -h, --help       Show help                                           [boolean]
  -v, --version    Show version number                                 [boolean]

Visualises JavaScript, TypeScript and Flow codebases as meaningful and
committable architecture diagrams https://arkit.pro
"
`;

