exports[`CLI Angular2 Todo exclude and puml should output correct puml 1`] = `
"Running against __dirname/angular2_es2015 with the following config:
{
  "components": [
    {
      "type": "Dependency",
      "patterns": [
        "node_modules/*"
      ]
    },
    {
      "type": "Component",
      "patterns": [
        "**/*.ts",
        "**/*.js",
        "**/*.jsx",
        "**/*.tsx"
      ]
    },
    {
      "type": "Vue",
      "format": "full",
      "patterns": [
        "**/*.vue"
      ]
    }
  ],
  "excludePatterns": [
    "app/components/**"
  ],
  "output": [
    {
      "path": [
        "puml"
      ],
      "groups": [
        {
          "first": true,
          "components": [
            "Component",
            "Vue"
          ]
        },
        {
          "type": "Dependencies",
          "components": [
            "Dependency"
          ]
        }
      ]
    }
  ]
}

Note: Arkit now uses LOCAL PlantUML conversion (requires Java JRE 8+).
Your code stays private and never leaves your machine. No external service calls.

@startuml

scale max 1920 width
top to bottom direction

skinparam nodesep 12
skinparam ranksep 25
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Tahoma
skinparam defaultFontSize 12
skinparam roundCorner 6
skinparam dpi 150
skinparam arrowColor black
skinparam arrowThickness 0.5
skinparam packageTitleAlignment left

' oval
skinparam usecase {
  borderThickness 0.5
}

' rectangle
skinparam rectangle {
  borderThickness 0.5
}

' component
skinparam component {
  borderThickness 1
}


(<b>main</b>)
(<b>main.bundle</b>)
(main.module)
(pipes)
(routes)
(todo-store.service)
rectangle "todo.model" as _todo_model
(trim.pipe)
(<b>webpack.config</b>)


(<b>main</b>) -[thickness=1]> (main.module)
(main.module) --> (pipes)
(main.module) --> (routes)
(main.module) --> (todo-store.service)
(pipes) --> (trim.pipe)
(todo-store.service) --> _todo_model

@enduml

' View and edit on https://arkit.pro
"
`;

