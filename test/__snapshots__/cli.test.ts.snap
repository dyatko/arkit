@startuml

scale max 0 width
left to right direction

skinparam nodesep 0
skinparam ranksep 0
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Tahoma
skinparam defaultFontSize 0
skinparam roundCorner 0
skinparam dpi 0
skinparam arrowColor black
skinparam arrowThickness 0
skinparam packageTitleAlignment left

skinparam usecase {
  borderThickness 0
}

skinparam rectangle {
  borderThickness 0
}

skinparam component {
  borderThickness 0
}


(<b>index</b>)
(<b>server</b>)
(server.node)
[<b>shared</b>] as _shared

package "Events" {
  (BeforeInputEventPlugin)
  (ChangeEventPlugin)
  (DOMEventPluginOrder)
  rectangle "DOMTopLevelEventTypes" as _DOMTopLevelEventTypes
  (EnterLeaveEventPlugin)
  (EventListener)
  (FallbackCompositionState)
  (getEventCharCode)
  (getEventKey)
  (getEventModifierState)
  (getEventTarget)
  (getVendorPrefixedEventName)
  (isEventSupported)
  (ReactBrowserEventEmitter)
  (ReactDOMEventListener)
  (SelectEventPlugin)
  (SimpleEventPlugin)
  (SyntheticAnimationEvent)
  (SyntheticClipboardEvent)
  (SyntheticCompositionEvent)
  (SyntheticDragEvent)
  (SyntheticFocusEvent)
  (SyntheticInputEvent)
  (SyntheticKeyboardEvent)
  (SyntheticMouseEvent)
  (SyntheticPointerEvent)
  (SyntheticTouchEvent)
  (SyntheticTransitionEvent)
  (SyntheticUIEvent)
  (SyntheticWheelEvent)
}

package "Client" {
  (DOMPropertyOperations)
  (getActiveElement)
  (getNodeForCharacterOffset)
  (inputValueTracking)
  rectangle "ReactDOM" as _ReactDOM
  (ReactDOMClientInjection)
  (ReactDOMComponent)
  (ReactDOMComponentTree)
  (ReactDOMInput)
  (ReactDOMOption)
  (ReactDOMSelect)
  (ReactDOMSelection)
  (ReactDOMTextarea)
  (ReactInputSelection)
  (setInnerHTML)
  (setTextContent)
  (ToStringValue)
}

package "Server" {
  (DOMMarkupOperations)
  (escapeTextForBrowser)
  (quoteAttributeValueForBrowser)
  (ReactDOMNodeStreamRenderer)
  (ReactDOMServerNode)
  (ReactDOMStringRenderer)
  (ReactPartialRenderer)
  (ReactPartialRendererContext)
  rectangle "ReactPartialRendererHooks" as _ReactPartialRendererHooks
  rectangle "ReactThreadIDAllocator" as _ReactThreadIDAllocator
}

(BeforeInputEventPlugin) ..> _DOMTopLevelEventTypes
(BeforeInputEventPlugin) ..> (FallbackCompositionState)
(BeforeInputEventPlugin) ..> (SyntheticCompositionEvent)
(BeforeInputEventPlugin) ..> (SyntheticInputEvent)
(ChangeEventPlugin) ..> _DOMTopLevelEventTypes
(ChangeEventPlugin) ..> (getEventTarget)
(ChangeEventPlugin) - -> (inputValueTracking)
(ChangeEventPlugin) ..> (isEventSupported)
(ChangeEventPlugin) - -> (ReactDOMComponentTree)
(ChangeEventPlugin) - -> (ReactDOMInput)
(DOMMarkupOperations) ..> (quoteAttributeValueForBrowser)
(DOMMarkupOperations) - -> _shared
(DOMPropertyOperations) - -> _shared
_DOMTopLevelEventTypes ..> (getVendorPrefixedEventName)
(EnterLeaveEventPlugin) ..> _DOMTopLevelEventTypes
(EnterLeaveEventPlugin) - -> (ReactDOMComponentTree)
(EnterLeaveEventPlugin) ..> (SyntheticMouseEvent)
(EnterLeaveEventPlugin) ..> (SyntheticPointerEvent)
(getEventKey) ..> (getEventCharCode)
(getEventTarget) - -> _shared
(getNodeForCharacterOffset) - -> _shared
(<b>index</b>) - -[thickness=0]> _ReactDOM
(quoteAttributeValueForBrowser) ..> (escapeTextForBrowser)
(ReactBrowserEventEmitter) ..> _DOMTopLevelEventTypes
(ReactBrowserEventEmitter) ..> (isEventSupported)
(ReactBrowserEventEmitter) ..> (ReactDOMEventListener)
_ReactDOM ..> (ReactDOMClientInjection)
_ReactDOM ..> (ReactDOMComponent)
_ReactDOM ..> (ReactDOMComponentTree)
_ReactDOM - -> (ReactDOMEventListener)
_ReactDOM - -> _shared
(ReactDOMClientInjection) - -> (BeforeInputEventPlugin)
(ReactDOMClientInjection) - -> (ChangeEventPlugin)
(ReactDOMClientInjection) - -> (DOMEventPluginOrder)
(ReactDOMClientInjection) - -> (EnterLeaveEventPlugin)
(ReactDOMClientInjection) ..> (ReactDOMComponentTree)
(ReactDOMClientInjection) - -> (SelectEventPlugin)
(ReactDOMClientInjection) - -> (SimpleEventPlugin)
(ReactDOMComponent) ..> (DOMPropertyOperations)
(ReactDOMComponent) - -> _DOMTopLevelEventTypes
(ReactDOMComponent) ..> (inputValueTracking)
(ReactDOMComponent) - -> (ReactBrowserEventEmitter)
(ReactDOMComponent) ..> (ReactDOMInput)
(ReactDOMComponent) ..> (ReactDOMOption)
(ReactDOMComponent) ..> (ReactDOMSelect)
(ReactDOMComponent) ..> (ReactDOMTextarea)
(ReactDOMComponent) ..> (setInnerHTML)
(ReactDOMComponent) ..> (setTextContent)
(ReactDOMComponent) - -> _shared
(ReactDOMEventListener) ..> _DOMTopLevelEventTypes
