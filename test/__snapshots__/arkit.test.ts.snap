<b>main.ts</b> to main.view--><path d="M0,0 C0,0 0,0 0,0 " fill="none" id="&lt;b&gt;main.ts&lt;/b&gt;-main.view" style="stroke: #0; stroke-width: 0;"/><!--link <b>main.ts</b> to utils.ts--><path d="M0,0 C0,0 0,0 0,0 " fill="none" id="&lt;b&gt;main.ts&lt;/b&gt;-utils.ts" style="stroke: #0; stroke-width: 0;"/><!--link main.view to _component--><!--link main.view to singleton--><!--link singleton to _model--><!--link utils.ts to _model--><!--
