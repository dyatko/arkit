  borderThickness 1
}


package "Main" {
  (main.view)
  (singleton)
}

package "Base" {
  (base.component)
  rectangle "component" as _component
  rectangle "model" as _model
}

(<b>main.ts</b>)
(utils.ts)

_component ..> (base.component)
(<b>main.ts</b>) -[thickness=1]> (main.view)
(<b>main.ts</b>) -[thickness=1]> (utils.ts)
(main.view) --> _component
(main.view) ..> (singleton)
(singleton) --> _model
(utils.ts) --> _model

@enduml

